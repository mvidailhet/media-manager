{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Media Manager",
  "version": "0.1.0",
  "identifier": "com.mvidailhet.media-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Media Manager",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "targets": "all"
  }
}
